# ccswresp Configuration
# Copy this file to .env and edit the values.

# Your API key for the LLM provider
api_key=sk-your-api-key-here

# Optional: Override the base URL for Chat Completions API
# Default: https://api.deepseek.com
base_url=https://api.deepseek.com

# Optional: Default model name (used when client doesn't specify or sends a GPT model)
# Default: deepseek-v4-pro
model=deepseek-v4-pro

# Optional: Server port (default: 11435)
port=11435
